apiVersion: v1
kind: ConfigMap
metadata:
  name: frontend-entrypoint-config
  namespace: dialerv2test
data:
  entrypoint.sh: |
    #!/bin/sh
    set -eu

    # Fix API URLs in built JS
    for f in /usr/share/nginx/html/assets/*.js; do
      sed -i "s|http://127.0.0.1:3100||g" "$f" || true
    done

    # Generate nginx config
    cat > /etc/nginx/conf.d/default.conf <<'NGINXCONF'
    server {
      listen 8088;
      server_name _;

      root /usr/share/nginx/html;
      index index.html;

      location /auth/ {
        proxy_pass http://127.0.0.1:3100;
      }

      location /admin/ {
        proxy_pass http://127.0.0.1:3100;
      }

      location / {
        try_files $uri /index.html;
      }

      location /sip-ws {
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_pass http://__POD_IP__:5066;
      }
    }
    NGINXCONF

    # Replace POD_IP dynamically
    sed -i "s|__POD_IP__|${POD_IP}|g" /etc/nginx/conf.d/default.conf

    exec nginx -g "daemon off;"