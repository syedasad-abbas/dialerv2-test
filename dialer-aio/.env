# =========================
# Core / Runtime
# =========================
LOG_LEVEL=info
HEALTH_PORT=3000
MAX_CALL_DURATION_MS=180000

# =========================
# FreeSWITCH ESL
# =========================
FREESWITCH_HOST=127.0.0.1
FREESWITCH_PORT=8021
FREESWITCH_PASSWORD=ClueCon

# If set, dialer uses named gateway route:
# sofia/gateway/${SIP_GATEWAY}/${number}
SIP_GATEWAY=
SIP_PROFILE=external
CODEC_STRING=PCMU,PCMA
ORIGINATE_TIMEOUT_SEC=60
ESL_RECONNECT_MS=5000

# Used when SIP_GATEWAY is empty (round-robin)
SIP_TRUNK_IPS=169.197.85.202,169.197.85.203,169.197.85.204

# =========================
# RabbitMQ
# =========================
RABBITMQ_URI=amqp://guest:guest@127.0.0.1:5672
RABBITMQ_CALLS_QUEUE=calls_queue
RABBITMQ_PREFETCH=60
RABBITMQ_QUEUE_TYPE=quorum
RABBITMQ_RECONNECT_MS=5000

# =========================
# Redis
# =========================
REDIS_URI=redis://127.0.0.1:6379
ANSWERED_CALL_KEY_TTL=14760
INFLIGHT_KEY_TTL=120

# =========================
# Call status API
# =========================
CALL_STATUS_API_BASE_URL=https://portal.dialytica.com/api
CALL_STATUS_API_TIMEOUT=5000

# =========================
# Dialing / IVR
# =========================
CALLS_PER_SECOND=30
DTMF_GATHER_TIMEOUT=15
DEFAULT_NUMBER_PREFIX=
AUDIO_CACHE_PREFIX=http_cache://
VM_PLAYBACK_START_DELAY_MS=180
VM_REMOTE_SILENCE_REQUIRED_MS=900
VM_REMOTE_SILENCE_MAX_WAIT_MS=4000

# =========================
# Node DSP Beep Detection (Primary)
# =========================
BEEP_NODE_DETECTOR_ENABLED=true
BEEP_NODE_WS_HOST=0.0.0.0
BEEP_NODE_WS_PORT=8090
BEEP_NODE_SAMPLE_RATE=8000
BEEP_NODE_SILENCE_RMS=220
BEEP_NODE_SILENCE_MIN_MS=700
BEEP_NODE_BEEP_BAND_LOW_HZ=850
BEEP_NODE_BEEP_BAND_HIGH_HZ=1250
BEEP_NODE_BEEP_BAND_RATIO=0.60
BEEP_NODE_BEEP_MIN_MS=120

# =========================
# AVMD / VMD Fallback (Optional)
# Keep off unless testing or using quorum mode
# =========================
BEEP_AVMD_ENABLED=false
BEEP_VMD_ENABLED=false
BEEP_REQUIRE_DUAL_SIGNAL=false
BEEP_MIN_MS_FROM_ANSWER=3000
BEEP_QUORUM_WINDOW_MS=2500
BEEP_SINGLE_SIGNAL_GRACE_MS=12000
BEEP_CONFIRM_DELAY_MS=350

# =========================
# Random Sampling Stream Mirror
# (When node detector is enabled, sampled audio is mirrored from Node)
# =========================
LISTEN_ENABLED=true
LISTEN_PROBABILITY=0.2
LISTEN_IPS=178.156.181.17,178.156.146.63,178.156.181.152,178.156.196.227,178.156.197.141
LISTEN_WEBSOCKET_PORT=8080
LISTEN_MIX_TYPE=stereo
LISTEN_SAMPLE_RATE=8000
LISTEN_MAX_LENGTH=20

BEEP_NODE_MIX_TYPE=stereo
BEEP_NODE_CUSTOMER_CHANNEL=left
LISTEN_CUSTOMER_SIDE_ONLY=true

TEST_CALL_API_ENABLED=false
TEST_CALL_API_PATH=/v1/test-call
TEST_CALL_API_KEY=
TEST_CALL_API_MAX_BODY_BYTES=262144
DISPOSITION_MAX_RETRIES=8
DISPOSITION_RETRY_BASE_MS=1000
DISPOSITION_RETRY_MAX_MS=60000
DISPOSITION_RETRY_JITTER_MS=500
DISPOSITION_QUEUE_MAX=50000
DISPOSITION_CONCURRENCY=16
DISPOSITION_DRAIN_TIMEOUT_MS=15000
