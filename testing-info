#orginating a call from freeswitch at defined did 

NS=dialerv2test
POD=$(kubectl get pod -n $NS -l app=dialer-freeswitch -o jsonpath='{.items[0].metadata.name}')

# watch dialer logs in one terminal
kubectl logs -n $NS $POD -c dialer-aio -f | egrep "Inbound call parked|Selected and locked agent|queue timeout|did NOT answer"

# simulate inbound DID call (no real phone call)
kubectl exec -n $NS $POD -c freeswitch -- fs_cli -x "reloadxml"
kubectl exec -n $NS $POD -c freeswitch -- fs_cli -H 127.0.0.1 -P 8021 -p 'FS!Secure2026' -x "bgapi originate {origination_caller_id_number=923001112233,loopback_export=call_role,call_type,route_group,inbound_did,inbound_from,call_role=inbound_customer,call_type=inbound,route_group=inbound,inbound_did=1234567890,inbound_from=923001112233}loopback/1234567890/public &park()"


#fake ws client to test redis functionality 

# send fake "portal login/presence" and keep socket open 120s
kubectl exec -n $NS $POD -c dialer-aio -- node -e '
const WebSocket=require("ws");
const ws=new WebSocket("ws://127.0.0.1:18081");
ws.on("open",()=>{ws.send(JSON.stringify({
  type:"agent_presence",
  agentId:"agent-1001",
  extension:"1001",
  sipRegistered:true,
  availableInbound:true,
  availableOutbound:true
}));
console.log("presence sent");
setTimeout(()=>ws.close(),120000);
});
setInterval(()=>{},1000);
'
