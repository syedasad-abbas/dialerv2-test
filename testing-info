#creating the fs-tl 
NS=dialerv2test

mkdir -p /tmp/fs-tls
openssl req -x509 -newkey rsa:2048 -nodes -days 365 \
  -keyout /tmp/fs-tls/tls.key \
  -out /tmp/fs-tls/tls.crt \
  -subj "/CN=localhost"

cat /tmp/fs-tls/tls.key /tmp/fs-tls/tls.crt > /tmp/fs-tls/wss.pem

kubectl -n $NS create secret generic fs-tls-certs \
  --from-file=wss.pem=/tmp/fs-tls/wss.pem \
  --dry-run=client -o yaml | kubectl apply -f -

kubectl rollout restart deployment/dialer-freeswitch -n $NS
kubectl get pods -n $NS -w

