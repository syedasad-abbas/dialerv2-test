AUTH_API_PORT=3100
REDIS_URI=redis://127.0.0.1:6379
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRES_IN=12h

# SIP data returned to frontend on login
SIP_DOMAIN=dialerv2.local
SIP_WS_URL=wss://127.0.0.1:7443

# One-time bootstrap admin (created if missing)
SEED_ADMIN_ON_START=true
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=Pass@123
SEED_ADMIN_NAME=Portal Admin
SEED_ADMIN_EXTENSION=1001
